<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #101720;
    --bg-panel: #161f2b;
    --bg-panel-2: #1c2733;
    --line: #2a3644;
    --text: #f1eee4;
    --text-dim: #8b98a4;
    --amber: #e0973f;
    --teal: #4aa8a0;
    --teal-soft: #4aa8a022;
    --amber-soft: #e0973f22;
    --danger: #d97757;
    --radius: 10px;
    --serif: 'Space Grotesk', sans-serif;
    --body: 'Inter', sans-serif;
    --mono: 'IBM Plex Mono', monospace;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:var(--body);
    line-height:1.6;
    overflow-x:hidden;
  }
  body::before{
    content:'';
    position:fixed; inset:0;
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size:64px 64px;
    opacity:0.12;
    pointer-events:none;
    z-index:0;
  }
  a{color:inherit;text-decoration:none;}
  .wrap{max-width:1080px;margin:0 auto;padding:0 28px;position:relative;z-index:1;}
  ::selection{background:var(--amber); color:#161f2b;}

  /* focus visibility */
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--teal);
    outline-offset:3px;
  }

  /* NAV */
  header{
    position:sticky; top:0; z-index:50;
    backdrop-filter:blur(10px);
    background:rgba(16,23,32,0.82);
    border-bottom:1px solid var(--line);
  }
  nav.wrap{
    display:flex; align-items:center; justify-content:space-between;
    height:64px;
  }
  .logo{
    font-family:var(--mono); font-size:15px; color:var(--amber);
    letter-spacing:0.5px;
  }
  .logo span{color:var(--text-dim);}
  .navlinks{display:flex; gap:28px; font-family:var(--mono); font-size:13px;}
  .navlinks a{color:var(--text-dim); transition:color .2s;}
  .navlinks a:hover{color:var(--teal);}
  .navlinks a::before{content:'./'; color:var(--line);}
  .navtoggle{display:none;}

  @media (max-width:720px){
    .navlinks{display:none;}
  }

  /* HERO */
  .hero{
    padding:96px 0 72px;
    display:grid; grid-template-columns:1.3fr 1fr; gap:48px; align-items:start;
  }
  @media (max-width:860px){ .hero{grid-template-columns:1fr;} }

  .terminal{
    background:var(--bg-panel);
    border:1px solid var(--line);
    border-radius:var(--radius);
    overflow:hidden;
    box-shadow:0 20px 60px -20px rgba(0,0,0,0.6);
  }
  .term-bar{
    display:flex; align-items:center; gap:8px;
    padding:10px 14px;
    background:var(--bg-panel-2);
    border-bottom:1px solid var(--line);
  }
  .dot{width:10px;height:10px;border-radius:50%;}
  .dot.r{background:#e0625f;} .dot.y{background:#e0b23f;} .dot.g{background:#4aa87a;}
  .term-title{margin-left:8px; font-family:var(--mono); font-size:12px; color:var(--text-dim);}
  .term-body{padding:26px 28px 32px; font-family:var(--mono);}
  .term-line{font-size:13px; color:var(--text-dim); margin-bottom:6px;}
  .term-line .prompt{color:var(--teal); margin-right:8px;}
  .term-name{
    font-family:var(--serif); font-weight:700;
    font-size:clamp(32px,5vw,46px);
    margin:14px 0 4px;
    color:var(--text);
  }
  .term-role{
    font-size:16px; color:var(--amber); font-family:var(--mono); margin-bottom:18px;
  }
  .cursor{display:inline-block; width:9px; height:18px; background:var(--amber); vertical-align:middle; animation:blink 1s step-end infinite;}
  @keyframes blink{50%{opacity:0;}}

  .badges{display:flex; flex-wrap:wrap; gap:8px; margin:18px 0 26px;}
  .badge{
    font-family:var(--mono); font-size:11.5px; letter-spacing:0.3px;
    padding:5px 11px; border-radius:100px;
    border:1px solid var(--line); color:var(--text-dim);
    background:var(--bg-panel-2);
  }
  .badge b{color:var(--teal); font-weight:600;}

  .cta-row{display:flex; gap:12px; flex-wrap:wrap;}
  .btn{
    font-family:var(--mono); font-size:13px;
    padding:11px 18px; border-radius:6px;
    border:1px solid var(--line);
    transition:all .2s;
    display:inline-flex; align-items:center; gap:8px;
  }
  .btn.primary{background:var(--amber); color:#171018; border-color:var(--amber); font-weight:600;}
  .btn.primary:hover{background:#f0a755;}
  .btn.ghost{color:var(--text); background:transparent;}
  .btn.ghost:hover{border-color:var(--teal); color:var(--teal);}

  /* status side panel */
  .status-panel{
    background:var(--bg-panel);
    border:1px solid var(--line);
    border-radius:var(--radius);
    padding:22px 22px 24px;
    font-family:var(--mono);
    height:fit-content;
  }
  .status-title{font-size:11px; color:var(--text-dim); letter-spacing:1px; text-transform:uppercase; margin-bottom:16px;}
  .status-row{display:flex; justify-content:space-between; font-size:13px; padding:9px 0; border-bottom:1px solid var(--line);}
  .status-row:last-child{border-bottom:none;}
  .status-row span:first-child{color:var(--text-dim);}
  .status-row span:last-child{color:var(--teal); font-weight:500;}
  .pulse{width:7px;height:7px;border-radius:50%;background:var(--teal); display:inline-block; margin-right:6px; box-shadow:0 0 0 rgba(74,168,160,0.6); animation:pulse 2s infinite;}
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(74,168,160,0.5);}
    70%{box-shadow:0 0 0 8px rgba(74,168,160,0);}
    100%{box-shadow:0 0 0 0 rgba(74,168,160,0);}
  }

  /* SECTION HEADERS */
  section{padding:64px 0; position:relative; z-index:1;}
  .sec-head{display:flex; align-items:baseline; gap:14px; margin-bottom:40px;}
  .sec-tag{font-family:var(--mono); font-size:12px; color:var(--amber); white-space:nowrap;}
  .sec-title{font-family:var(--serif); font-size:clamp(24px,3vw,32px); font-weight:600;}
  .sec-rule{flex:1; height:1px; background:var(--line);}

  /* ABOUT - log style */
  .log{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:8px 0; font-family:var(--mono); font-size:14px; overflow:hidden;
  }
  .log-line{display:flex; gap:18px; padding:11px 24px; border-bottom:1px solid var(--line); color:var(--text-dim);}
  .log-line:last-child{border-bottom:none;}
  .log-line .ln{color:#4a5764; user-select:none; min-width:20px;}
  .log-line .tag{color:var(--teal); min-width:78px;}
  .log-line .msg{color:var(--text); font-family:var(--body); font-size:15px; line-height:1.5;}

  /* SKILLS - network topology */
  .topology{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:40px 20px;
  }
  .topo-svg{width:100%; height:auto; display:block;}
  .node-label{font-family:var(--mono); font-size:12px; fill:var(--text); font-weight:500;}
  .node-sub{font-family:var(--body); font-size:10.5px; fill:var(--text-dim);}
  .edge{stroke:var(--line); stroke-width:1.5;}
  .packet{fill:var(--amber);}
  .node-circle{fill:var(--bg-panel-2); stroke:var(--teal); stroke-width:1.5;}
  .node-circle.core{stroke:var(--amber);}

  /* CERTS */
  .cert-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:16px;}
  @media (max-width:780px){.cert-grid{grid-template-columns:1fr 1fr;}}
  @media (max-width:520px){.cert-grid{grid-template-columns:1fr;}}
  .cert-card{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:20px; transition:transform .2s, border-color .2s;
  }
  .cert-card:hover{transform:translateY(-3px); border-color:var(--teal);}
  .cert-src{font-family:var(--mono); font-size:11px; color:var(--amber); letter-spacing:0.5px; margin-bottom:10px;}
  .cert-name{font-weight:600; font-size:15px; margin-bottom:6px;}
  .cert-meta{font-family:var(--mono); font-size:11.5px; color:var(--text-dim);}

  /* PROJECTS */
  .proj-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:18px;}
  @media (max-width:860px){.proj-grid{grid-template-columns:1fr;}}
  .proj-card{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:22px; display:flex; flex-direction:column; gap:12px;
    transition:border-color .2s, transform .2s;
  }
  .proj-card:hover{border-color:var(--amber); transform:translateY(-3px);}
  .proj-top{display:flex; justify-content:space-between; align-items:flex-start;}
  .proj-name{font-family:var(--mono); font-weight:600; font-size:14.5px; color:var(--text);}
  .proj-branch{font-family:var(--mono); font-size:11px; color:var(--teal); background:var(--teal-soft); padding:3px 8px; border-radius:100px;}
  .proj-desc{font-size:13.5px; color:var(--text-dim); flex:1;}
  .proj-stack{display:flex; flex-wrap:wrap; gap:6px;}
  .stack-tag{font-family:var(--mono); font-size:10.5px; color:var(--text-dim); border:1px solid var(--line); padding:3px 8px; border-radius:5px;}
  .proj-note{font-family:var(--mono); font-size:11px; color:#5a6875; border-top:1px dashed var(--line); padding-top:10px; margin-top:2px;}

  /* CONTACT */
  .contact-box{
    background:var(--bg-panel); border:1px solid var(--line); border-radius:var(--radius);
    padding:36px; font-family:var(--mono);
  }
  .contact-cmd{color:var(--text-dim); font-size:14px; margin-bottom:22px;}
  .contact-cmd .prompt{color:var(--teal); margin-right:8px;}
  .contact-cmd .flag{color:var(--amber);}
  .contact-links{display:flex; flex-wrap:wrap; gap:14px;}
  .contact-link{
    display:flex; align-items:center; gap:10px;
    padding:13px 18px; border:1px solid var(--line); border-radius:8px;
    font-size:13.5px; color:var(--text); transition:all .2s; flex:1; min-width:200px;
  }
  .contact-link:hover{border-color:var(--teal); background:var(--teal-soft);}
  .contact-link .ico{color:var(--amber); font-family:var(--serif); font-weight:700;}

  footer{
    padding:32px 0 48px; text-align:center; font-family:var(--mono); font-size:12px; color:var(--text-dim);
  }

  .reveal{opacity:0; transform:translateY(16px); transition:opacity .6s ease, transform .6s ease;}
  .reveal.show{opacity:1; transform:none;}

  @media (prefers-reduced-motion: reduce){
    *{animation:none !important; transition:none !important;}
    .reveal{opacity:1; transform:none;}
  }
</style>
</head>
